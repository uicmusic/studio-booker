// This is your Prisma schema file,
// learn more here: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          String    @default("STUDENT")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
  approvedBookings Booking[] @relation("ApprovedBy")
  
  @@map("users")
}

model Studio {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  location    String?
  capacity    Int?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
  images      String?   // JSON string array
  
  @@map("studios")
}

model Equipment {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  quantity    Int       @default(0)
  available   Int       @default(0)
  category    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    BookingEquipment[]
  
  @@map("equipments")
}

model Booking {
  id              String   @id @default(cuid())
  userId          String
  studioId        String
  startDate       DateTime
  endDate         DateTime
  purpose         String
  status          String   @default("PENDING")
  approvedById    String?
  approvedBy      User?    @relation("ApprovedBy", fields: [approvedById], references: [id])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studio          Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  equipment       BookingEquipment[]
  returnProofs    ReturnProof[]
  isOverdue       Boolean  @default(false)
  autoReturnedAt  DateTime?
  
  @@map("bookings")
}

model BookingEquipment {
  id          String   @id @default(cuid())
  bookingId   String
  equipmentId String
  quantity    Int
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  
  @@unique([bookingId, equipmentId])
  @@map("booking_equipments")
}

model ReturnProof {
  id          String   @id @default(cuid())
  bookingId   String
  images      String?  // JSON string array
  description String?
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  @@map("return_proofs")
}
