# Prisma → Supabase Postgres (Settings → Database → Connection string → URI)
# Use port 5432 (direct) for local migrate/push, or pooler URI + DIRECT_URL per Supabase + Prisma docs.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# NextAuth
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"
# Must match the URL in the browser exactly (port included). Typo 30001 → login fails.
NEXTAUTH_URL="http://localhost:3000"
